    "jest-junit": "^16.0.0",
    "patch-package": "^8.0.0",
    "qrcode": "^1.5.4",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@isaacs/brace-expansion": "5.0.1",
    "tar": "7.5.8",
    "minimatch": "10.2.3",
    "@tootallnate/once": "3.0.1",
    "@react-native-async-storage/async-storage": "^2.2.0"
  }
}
