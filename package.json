{
  "name": "culturepass-app",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "start": "npx expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "build": "npm run expo:static:build",
    "expo:static:build": "node scripts/build.js",
    "functions:build": "cd functions && npm run build",
    "server:dev": "tsx scripts/server-dev.ts",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "typecheck": "tsc --noEmit",
    "test:native-intent": "tsx scripts/test-native-intent.ts",
    "test:unit": "tsx scripts/tests/unit-services-middleware.ts && tsx scripts/tests/unit-locations.ts && tsx scripts/tests/unit-functions-authz-policy.ts",
    "test:integration": "tsx scripts/tests/integration-api-routes.ts",
    "test:integration:functions:council-claims": "tsx scripts/tests/integration-functions-council-claims.ts",
    "test:e2e:smoke": "tsx scripts/tests/e2e-critical-smoke.ts",
    "qa:all": "npm run test:package-json && npx tsx scripts/tests/test-deeplinks.ts && npm run test:unit && npm run test:integration && npm run test:e2e:smoke",
    "qa:solid": "npm run lint && npm run typecheck && npm run qa:all && npm run test:integration:functions:council-claims && npm run functions:build && npm run build-web",
    "test:package-json": "tsx scripts/tests/validate-package-json.ts",
    "build-web": "npx expo export --platform web",
    "deploy-web": "npm run build-web && firebase deploy --only hosting",
    "backup": "git add . && git diff --cached --quiet || git commit -m 'Auto-deploy backup'",
    "deploy-all": "npm run typecheck && npm run backup && git push origin main && npm run functions:build && firebase deploy --only functions,hosting",
    "deploy:guarded": "npm run qa:solid && npm run deploy-all",
    "build:ios:device": "eas build --platform ios --profile device",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:ios:production": "eas build --platform ios --profile production",
    "build:android:production": "eas build --platform android --profile production",
    "submit:ios:production": "eas submit --platform ios --profile production",
    "submit:android:production": "eas submit --platform android --profile production",
    "update:preview": "eas update --branch preview",
    "update:production": "eas update --branch production"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
