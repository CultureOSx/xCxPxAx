# ──────────────────────────────────────────────────────────────────────────────
# CulturePass AU — Environment Variables
# Copy this file to .env and fill in your values (never commit .env)
# Get Firebase values from: Firebase Console → Project Settings → Your apps → Web app
# ──────────────────────────────────────────────────────────────────────────────

# Firebase Client SDK (baked into bundle at build time via EXPO_PUBLIC_*)
// Import the functions you need from the SDKs you need
import { initializeApp } from "firebase/app";
import { getAnalytics } from "firebase/analytics";
// TODO: Add SDKs for Firebase products that you want to use
// https://firebase.google.com/docs/web/setup#available-libraries

// Your web app's Firebase configuration
// For Firebase JS SDK v7.20.0 and later, measurementId is optional
const firebaseConfig = {
  apiKey: "AIzaSyDjAJFTdTfkP63pjuQd7j41DNEKYAYYupw",
  authDomain: "culturepass-4f264.firebaseapp.com",
  projectId: "culturepass-4f264",
  storageBucket: "culturepass-4f264.firebasestorage.app",
  messagingSenderId: "476251116440",
  appId: "1:476251116440:web:d17db0b0419cb8915151ed",
  measurementId: "G-B31241101C"
};

// Initialize Firebase
const app = initializeApp(firebaseConfig);
const analytics = getAnalytics(app);

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# API base URL
# Production:  https://us-central1-YOUR_PROJECT.cloudfunctions.net/api/
# Emulator:    http://localhost:5001/YOUR_PROJECT/us-central1/api/
EXPO_PUBLIC_API_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/api/

# Algolia — client search (search-only API key only; never the Admin key)
# Indices: culturepass_events, culturepass_profiles (see functions/src/services/algolia.ts)
# Local: fill below. EAS production: add the same keys to build.production.env in eas.json
#   OR set them in Expo → Project → Environment variables (do not commit real keys).
#   Avoid empty EXPO_PUBLIC_ALGOLIA_* entries in eas.json — they override dashboard secrets.
EXPO_PUBLIC_ALGOLIA_APP_ID=
EXPO_PUBLIC_ALGOLIA_SEARCH_KEY=

# Firebase Emulator (set to true only when running `firebase emulators:start`)
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=localhost

# Social Auth
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_GOOGLE_REVERSED_CLIENT_ID=

# Analytics (optional)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
