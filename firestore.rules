rules_version = '2';

/**
 * CulturePassAU — Firestore Security Rules
 *
 * Role hierarchy (weakest → strongest):
 *   user(0) < organizer=business=sponsor(1) < cityAdmin(2) < moderator(3) < admin=platformAdmin(4)
 *
 * Design principles:
 *   1. Deny by default — every unmatched path is rejected by the catch-all at the bottom.
 *   2. Ownership beats role — prefer `isOwner` before escalating to role checks.
 *   3. Separate create / update / delete — never collapse all writes into one `write` rule
 *      unless the logic is truly identical for all three operations.
 *   4. Never trust client-supplied IDs for ownership — always verify against token.uid.
 *   5. Admin SDK (Cloud Functions) bypasses these rules entirely — this file only
 *      governs direct client SDK writes, which should be rare or non-existent for
 *      sensitive mutations (tickets, wallets, memberships).
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // ─── Helper functions ────────────────────────────────────────────────────
    // =========================================================================

    /** Is a valid Firebase session present? */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Shorthand for the current user's uid. */
    function uid() {
      return request.auth.uid;
    }

    /** Custom-claims token object. */
    function token() {
      return request.auth.token;
    }

    /**
     * Role rank — mirrors the backend ROLE_RANK in middleware/auth.ts.
     * Stored as a custom claim `role` via Admin SDK setCustomUserClaims().
     *
     * user(0) < organizer=business=sponsor(1) < cityAdmin(2) < moderator(3) < admin=platformAdmin(4)
     */
    function roleRank() {
      return
        token().role == 'platformAdmin' ? 4 :
        token().role == 'admin'         ? 4 :
        token().role == 'moderator'     ? 3 :
        token().role == 'cityAdmin'     ? 2 :
        token().role == 'organizer'     ? 1 :
        token().role == 'business'      ? 1 :
        token().role == 'sponsor'       ? 1 :
        0; // 'user' or unknown
    }

    /** Platform admin or super-admin. */
    function isAdmin() {
      return isSignedIn() && roleRank() >= 4;
    }

    /** Can review reported content, manage moderation queue. */
    function isModerator() {
      return isSignedIn() && roleRank() >= 3;
    }

    /** Can manage content within their assigned city. */
    function isCityAdmin() {
      return isSignedIn() && roleRank() >= 2;
    }

    /** Can create events, profiles, communities, activities. */
    function isOrganizer() {
      return isSignedIn() && roleRank() >= 1;
    }

    /** Exact role match — use for single-role checks only. */
    function hasExactRole(role) {
      return isSignedIn() && token().role == role;
    }

    /** Current user is the resource's owner (token uid matches stored uid). */
    function isOwner(ownerUid) {
      return isSignedIn() && uid() == ownerUid;
    }

    /** Owner OR admin — the most common pattern for sensitive docs. */
    function isOwnerOrAdmin(ownerUid) {
      return isOwner(ownerUid) || isAdmin();
    }

    /** Owner OR moderator — for user-generated content that mods can review. */
    function isOwnerOrModerator(ownerUid) {
      return isOwner(ownerUid) || isModerator();
    }

    /**
     * City-scoped admin check.
     * cityAdmin users have a `city` claim set to the city they manage.
     */
    function isCityAdminFor(city) {
      return isCityAdmin() && token().city == city;
    }

    /**
     * Reads a parent document to verify ownership.
     * Use sparingly — each get() costs a billed read.
     */
    function eventOwnerId(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data.organizerId;
    }

    function communityOwnerId(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)).data.ownerId;
    }

    function councilClaimedBy(councilId) {
      return get(/databases/$(database)/documents/councils/$(councilId)).data.claimedBy;
    }


    // =========================================================================
    // ─── Users ───────────────────────────────────────────────────────────────
    // =========================================================================
    /**
     * Full user document: email, role, membership, subscription, interests.
     * Only the owner and moderators+ can read the full document.
     * Public profile data is exposed via /profiles/ instead.
     */
    match /users/{userId} {
      allow read:   if isOwnerOrModerator(userId);
      allow create: if isOwner(userId)
                    // Prevent client from self-assigning elevated roles
                    && !request.resource.data.keys().hasAny(['role', 'stripeCustomerId', 'stripeSubscriptionId']);
      allow update: if (isOwner(userId)
                        // Owner cannot change their own role or payment fields
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role', 'stripeCustomerId', 'stripeSubscriptionId', 'membership', 'culturePassId']))
                    || isAdmin();
      allow delete: if isAdmin();

      // ── User-private subcollections ──────────────────────────────────────
      match /savedEvents/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /calendar/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /preferences/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Notifications under user: owner reads, Admin SDK creates (create=false for clients)
      match /notifications/{notifId} {
        allow read:          if isOwner(userId) || isAdmin();
        allow create:        if false;            // Admin SDK only
        allow update:        if isOwner(userId);  // e.g. mark as read
        allow delete:        if isOwner(userId) || isAdmin();
      }

      // Perks / redemption history under user: owner only
      match /perks/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Communities joined list under user: owner only
      match /communities/{docId} {
        allow read, write: if isOwner(userId);
      }
    }


    // =========================================================================
    // ─── Events ──────────────────────────────────────────────────────────────
    // =========================================================================
    match /events/{eventId} {
      /**
       * Read rules:
       *  - Published events: everyone (unauthenticated browsing)
       *  - Draft/cancelled events: only the organizer who owns it, or moderator+
       */
      allow read: if resource.data.status == 'published'
                  || isOwner(resource.data.organizerId)
                  || isModerator();

      /**
       * Create: must have organizer+ role AND the new doc's organizerId must
       * match the caller's uid (prevents impersonation).
       */
      allow create: if isOrganizer()
                    && request.resource.data.organizerId == uid()
                    && request.resource.data.keys().hasAll(['title', 'date', 'organizerId']);

      /**
       * Update: only the event's own organizer OR an admin.
       * Also prevents changing the organizerId after creation.
       */
      allow update: if (isOwner(resource.data.organizerId) || isAdmin())
                    && request.resource.data.organizerId == resource.data.organizerId;

      /**
       * Delete: event owner or admin (hard delete; prefer soft via status=deleted).
       */
      allow delete: if isOwner(resource.data.organizerId) || isAdmin();

      // ── Event subcollections ──────────────────────────────────────────────

      // Attendees: public read (social proof); auth users manage their own entry
      match /attendees/{attendeeId} {
        allow read:          if true;
        allow create:        if isOwner(attendeeId);
        allow update, delete: if isOwner(attendeeId) || isAdmin();
      }

      // Likes: public read; only the authenticated user can toggle their own
      match /likes/{userId} {
        allow read:          if true;
        allow create, delete: if isOwner(userId);
        allow update:        if false;
      }

      // Reviews: public read; authenticated write of own review
      match /reviews/{reviewId} {
        allow read:          if true;
        allow create:        if isSignedIn()
                             && request.resource.data.authorId == uid();
        allow update:        if isOwner(resource.data.authorId)
                             // Cannot change the authorId
                             && request.resource.data.authorId == resource.data.authorId;
        allow delete:        if isOwner(resource.data.authorId) || isModerator();
      }

      // Comments: public read; authenticated write of own comment
      match /comments/{commentId} {
        allow read:          if true;
        allow create:        if isSignedIn()
                             && request.resource.data.authorId == uid();
        allow update:        if isOwner(resource.data.authorId)
                             && request.resource.data.authorId == resource.data.authorId;
        allow delete:        if isOwner(resource.data.authorId) || isModerator();
      }

      // Media: public read; organizer of this event or admin can write
      match /media/{mediaId} {
        allow read:          if true;
        allow create:        if isOwner(eventOwnerId(eventId)) || isAdmin();
        allow update, delete: if isOwner(eventOwnerId(eventId)) || isAdmin();
      }

      // Tickets under an event: event organizer sees all; ticket owner sees their own
      match /tickets/{ticketId} {
        allow read: if isOwner(resource.data.userId)
                    || isOwner(eventOwnerId(eventId))
                    || isModerator();
        // Tickets are created by Cloud Functions (Admin SDK) — block all client creates/writes
        allow create, update, delete: if false;
      }
    }


    // =========================================================================
    // ─── Tickets (top-level collection) ──────────────────────────────────────
    // =========================================================================
    /**
     * Top-level tickets are written exclusively by Cloud Functions (Admin SDK).
     * The client SDK should never create, update, or delete a ticket directly.
     * Organizers can read tickets for events they own (via their event route instead).
     */
    match /tickets/{ticketId} {
      allow read:               if isOwner(resource.data.userId)
                                || isModerator();
      allow create:             if false; // Admin SDK only
      allow update:             if false; // Admin SDK only
      allow delete:             if false; // Admin SDK only
    }


    // =========================================================================
    // ─── Communities ─────────────────────────────────────────────────────────
    // =========================================================================
    match /communities/{communityId} {
      // Active communities are public; suspended/draft only visible to owner and mods
      allow read: if resource.data.status == 'active'
                  || isOwnerOrModerator(resource.data.ownerId);

      allow create: if isOrganizer()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.keys().hasAll(['name', 'ownerId']);

      allow update: if (isOwner(resource.data.ownerId) || isAdmin())
                    && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();

      // Members: public read; user joins/leaves their own entry; owner or admin manages others
      match /members/{memberId} {
        allow read:          if true;
        allow create:        if isSignedIn() && uid() == memberId;
        allow update, delete: if uid() == memberId
                              || isOwner(communityOwnerId(communityId))
                              || isAdmin();
      }

      // Events linked to community: community owner or admin
      match /events/{eventId} {
        allow read:  if true;
        allow write: if isOwner(communityOwnerId(communityId)) || isAdmin();
      }

      // Council link under community: admin only (structural data)
      match /council/{councilId} {
        allow read:  if true;
        allow write: if isAdmin();
      }
    }


    // =========================================================================
    // ─── Councils ────────────────────────────────────────────────────────────
    // =========================================================================
    /**
     * Both /councils/ (new) and /council/ (legacy) are kept in sync.
     * The same rule set applies to both.
     */
    match /councils/{councilId} {
      allow read:   if true; // Publicly browsable directory
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.claimedBy) || isAdmin();
      allow delete: if isAdmin();

      match /members/{memberId} {
        allow read:          if true;
        allow create:        if isSignedIn() && uid() == memberId;
        allow update, delete: if uid() == memberId || isAdmin();
      }

      match /events/{eventId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      match /facilities/{facilityId} {
        allow read:  if true;
        allow write: if isOwner(councilClaimedBy(councilId)) || isAdmin();
      }

      match /alerts/{alertId} {
        allow read:  if true;
        allow write: if isOwner(councilClaimedBy(councilId)) || isAdmin();
      }

      /**
       * Claims contain personal identification data.
       * Only the claimant and admins may read a claim.
       * Anyone authenticated may submit a new claim for themselves.
       */
      match /claims/{claimId} {
        allow read:   if isOwner(resource.data.userId) || isAdmin();
        allow create: if isSignedIn()
                      && request.resource.data.userId == uid()
                      // Rate-limit via field: only one active claim per user (enforced by Cloud Function)
                      && request.resource.data.status == 'pending';
        allow update: if isAdmin(); // Admin approves / rejects
        allow delete: if isAdmin();
      }
    }

    // ─── Legacy /council/ collection ─────────────────────────────────────────
    match /council/{councilId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.claimedBy) || isAdmin();
      allow delete: if isAdmin();

      match /members/{memberId} {
        allow read:          if true;
        allow create:        if isSignedIn() && uid() == memberId;
        allow update, delete: if uid() == memberId || isAdmin();
      }

      match /events/{eventId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      match /claims/{claimId} {
        allow read:   if isOwner(resource.data.userId) || isAdmin();
        allow create: if isSignedIn()
                      && request.resource.data.userId == uid()
                      && request.resource.data.status == 'pending';
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }


    // =========================================================================
    // ─── Profiles (public-facing entity pages) ───────────────────────────────
    // =========================================================================
    /**
     * Profiles represent communities, businesses, venues, artists, organisations.
     * They are publicly readable unless suspended.
     * Only the designated owner (ownerId) or admin can write.
     */
    match /profiles/{profileId} {
      allow read: if resource.data.status != 'suspended'
                  || isOwnerOrModerator(resource.data.ownerId);

      allow create: if isOrganizer()
                    && request.resource.data.ownerId == uid()
                    && request.resource.data.keys().hasAll(['name', 'ownerId', 'entityType']);

      allow update: if (isOwner(resource.data.ownerId) || isAdmin())
                    // Prevent ownership transfer without admin
                    && (request.resource.data.ownerId == resource.data.ownerId || isAdmin());

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }


    // =========================================================================
    // ─── Perks ───────────────────────────────────────────────────────────────
    // =========================================================================
    match /perks/{perkId} {
      allow read:               if true;
      allow create, update:     if isAdmin();
      allow delete:             if isAdmin();

      // Redemptions: only the redeemer and admin can see who redeemed what
      match /redemptions/{redemptionId} {
        allow read:   if isOwner(resource.data.userId) || isAdmin();
        allow create: if isSignedIn()
                      && request.resource.data.userId == uid()
                      && request.resource.data.perkId == perkId;
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }


    // =========================================================================
    // ─── Notifications (top-level) ───────────────────────────────────────────
    // =========================================================================
    match /notifications/{notificationId} {
      allow read:   if isOwner(resource.data.userId) || isAdmin();
      allow create: if false;           // Admin SDK only (push via Cloud Functions)
      allow update: if isOwner(resource.data.userId) || isAdmin(); // Mark as read
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }


    // =========================================================================
    // ─── Feed ────────────────────────────────────────────────────────────────
    // =========================================================================
    match /feed/{feedId} {
      allow read:               if isOwner(resource.data.userId) || isAdmin();
      allow create:             if false;  // Admin SDK only
      allow update:             if isOwner(resource.data.userId) || isAdmin();
      allow delete:             if isOwner(resource.data.userId) || isAdmin();
    }


    // =========================================================================
    // ─── Wallets ─────────────────────────────────────────────────────────────
    // =========================================================================
    /**
     * Wallet balance and transaction history are highly sensitive.
     * All mutations flow through Cloud Functions (Stripe webhooks, cashback).
     * Client SDK must never write directly.
     */
    match /wallets/{walletId} {
      allow read:               if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if false; // Admin SDK only
    }

    match /walletTransactions/{txId} {
      allow read:               if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if false; // Admin SDK only
    }


    // =========================================================================
    // ─── Memberships / Subscriptions ─────────────────────────────────────────
    // =========================================================================
    /**
     * Membership documents are written by Stripe webhook handlers (Admin SDK).
     * Clients may read their own membership to show tier UI.
     */
    match /memberships/{membershipId} {
      allow read:               if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if false; // Admin SDK via Stripe webhook
    }


    // =========================================================================
    // ─── Payment Methods ─────────────────────────────────────────────────────
    // =========================================================================
    match /paymentMethods/{methodId} {
      allow read:   if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(request.resource.data.userId); // User adds own card
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }


    // =========================================================================
    // ─── Reports / Moderation Queue ──────────────────────────────────────────
    // =========================================================================
    match /reports/{reportId} {
      allow read:   if isOwner(resource.data.reporterId) || isModerator();
      allow create: if isSignedIn()
                    && request.resource.data.reporterId == uid()
                    && request.resource.data.keys().hasAll(['reporterId', 'targetId', 'targetType', 'reason']);
      allow update: if isModerator(); // Moderators update status (resolved/dismissed)
      allow delete: if isAdmin();
    }


    // =========================================================================
    // ─── Scan Events (ticket scanner audit trail) ─────────────────────────────
    // =========================================================================
    match /scanEvents/{scanId} {
      allow read:               if isModerator() || isOwner(resource.data.scannedBy);
      allow create:             if isOrganizer(); // Scanner app creates entries
      allow update, delete:     if isAdmin();
    }


    // =========================================================================
    // ─── Locations ───────────────────────────────────────────────────────────
    // =========================================================================
    match /locations/{countryCode} {
      allow read: if true;
      allow write: if isAdmin();

      match /states/{stateCode} {
        allow read: if true;
        allow write: if isAdmin();

        match /cities/{cityId} {
          allow read: if true;
          allow write: if isAdmin();
        }
      }
    }


    // =========================================================================
    // ─── Feature Flags ───────────────────────────────────────────────────────
    // =========================================================================
    /**
     * Feature flag documents are read by clients to gate UI features.
     * Only admins can create/update flags.
     */
    match /featureFlags/{flagId} {
      allow read:               if true;
      allow create, update:     if isAdmin();
      allow delete:             if isAdmin();
    }


    // =========================================================================
    // ─── Media Uploads ───────────────────────────────────────────────────────
    // =========================================================================
    match /media/{mediaId} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.resource.data.uploadedBy == uid();
      allow update, delete: if isOwner(resource.data.uploadedBy) || isModerator();
    }


    // =========================================================================
    // ─── Audit Logs (immutable append-only) ──────────────────────────────────
    // =========================================================================
    /**
     * Audit logs are written exclusively by Cloud Functions.
     * Admins may read; nobody may delete or modify.
     */
    match /auditLogs/{logId} {
      allow read:               if isAdmin();
      allow create, update, delete: if false; // Admin SDK only — immutable
    }


    // =========================================================================
    // ─── Indigenous Content ───────────────────────────────────────────────────
    // =========================================================================
    match /indigenousSpotlights/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /traditionalLands/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }


    // =========================================================================
    // ─── Push Notification Tokens ────────────────────────────────────────────
    // =========================================================================
    /**
     * FCM tokens are sensitive — if leaked, anyone could send pushes.
     * Only the owner can read/write their own token document.
     */
    match /pushTokens/{userId} {
      allow read, write: if isOwner(userId);
    }


    // =========================================================================
    // ─── App Configuration (read-only for clients) ───────────────────────────
    // =========================================================================
    match /appConfig/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }


    // =========================================================================
    // ─── Community Posts (CultureFeed user-generated content) ────────────────
    // =========================================================================
    /**
     * User-created posts in the CultureFeed tied to a specific community.
     * Public read so anyone can browse; writes strictly require authentication.
     */
    match /communityPosts/{postId} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.resource.data.authorId == uid()
                    && request.resource.data.keys().hasAll(['authorId', 'communityId', 'body']);
      allow update: if isOwner(resource.data.authorId)
                    // Prevent changing ownership or community association
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['authorId', 'communityId']);
      allow delete: if isOwner(resource.data.authorId) || isModerator();

      // Comments on community posts
      match /comments/{commentId} {
        allow read:   if true;
        allow create: if isSignedIn()
                      && request.resource.data.authorId == uid()
                      && request.resource.data.keys().hasAll(['authorId', 'body']);
        allow update: if isOwner(resource.data.authorId)
                      && request.resource.data.authorId == resource.data.authorId;
        allow delete: if isOwner(resource.data.authorId) || isModerator();
      }

      // Per-user like documents — one doc per user per post
      match /likes/{userId} {
        allow read:          if true;
        allow create, delete: if isOwner(userId);
        allow update:        if false;
      }
    }


    // =========================================================================
    // ─── Default deny — catch-all ────────────────────────────────────────────
    // =========================================================================
    /**
     * Any collection or document path not explicitly matched above is denied.
     * This is the critical safety net — never remove it.
     */
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
