{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "@/lib/*": ["lib/*"],
      "@/hooks/*": ["hooks/*"],
      "@/contexts/*": ["contexts/*"],
      "@/constants/*": ["constants/*"],
      "@/components/*": ["components/*"],
      "@/shared/*": ["shared/*"],
      "@shared/*": ["shared/*"],
      "@/app/*": ["app/*"],
      "@/*": ["*"],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "functions",
    "scripts",
    "node_modules",
    "dist",
    "web",
    "server",
    "CulturePass",
    "tmp.auth-ui.spec.ts"
  ]
}