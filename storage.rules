rules_version = '2';

/**
 * CulturePass AU — Firebase Storage Rules
 *
 * Bucket layout:
 *   events/{uploaderId|eventId}/{filename}   — event banner/hero images
 *   profiles/{profileId}/{filename}          — artist / venue / business images
 *   communities/{communityId}/{filename}     — community cover images
 *   users/{userId}/{filename}                — user avatars (direct upload path)
 *   avatars/{userId}/{filename}              — user avatars (legacy path)
 *   posts/{userId}/{filename}                — feed post images
 *   perks/{perkId}/{filename}                — perk cover images (admin-managed)
 *   featuredCities/{cityId}/{filename}       — city hero images (admin-managed)
 *   uploads/{userId}/{filename}              — Cloud Functions staging (Admin SDK only)
 *
 * Role claims are set on the Firebase Auth ID token via Admin SDK (setCustomUserClaims).
 * Direct client uploads are allowed per the rules below; everything else uses Cloud
 * Functions (Admin SDK) which bypasses these rules entirely.
 */

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function role() {
      return isSignedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : '';
    }

    function isAdminLike() {
      return role() in ['admin', 'platformAdmin', 'cityAdmin', 'moderator'];
    }

    function isOrganizerLike() {
      return role() in ['organizer', 'business', 'sponsor', 'admin', 'platformAdmin', 'cityAdmin'];
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function underMB(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }

    // ── Events ──────────────────────────────────────────────────────────────
    // Covers both create flow (events/{userId}/…) and edit flow (events/{eventId}/…).
    // Organisers can write to any event folder; read is public.
    match /events/{allPaths=**} {
      allow read: if true;
      allow write: if isOrganizerLike()
                   && underMB(10)
                   && isValidImage();
    }

    // ── Profiles (artist / venue / business / community profile) ────────────
    match /profiles/{allPaths=**} {
      allow read: if true;
      allow write: if isOrganizerLike()
                   && underMB(10)
                   && isValidImage();
    }

    // ── Communities ─────────────────────────────────────────────────────────
    match /communities/{allPaths=**} {
      allow read: if true;
      allow write: if isOrganizerLike()
                   && underMB(10)
                   && isValidImage();
    }

    // ── User avatars — direct upload path used by profile/edit.tsx ──────────
    match /users/{userId}/{filename} {
      allow read: if true;
      allow write: if isOwner(userId)
                   && underMB(5)
                   && isValidImage();
    }

    // ── User avatars — legacy path ───────────────────────────────────────────
    match /avatars/{userId}/{filename} {
      allow read: if true;
      allow write: if isOwner(userId)
                   && underMB(5)
                   && isValidImage();
    }

    // ── Feed post images ─────────────────────────────────────────────────────
    match /posts/{userId}/{filename} {
      allow read: if true;
      allow write: if isOwner(userId)
                   && underMB(10)
                   && isValidImage();
    }

    // ── Perks — admin-managed content ───────────────────────────────────────
    match /perks/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminLike()
                   && underMB(10)
                   && isValidImage();
    }

    // ── Featured cities — admin-managed content ──────────────────────────────
    match /featuredCities/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminLike()
                   && underMB(10)
                   && isValidImage();
    }

    // ── Cloud Functions staging — Admin SDK writes only ──────────────────────
    match /uploads/{userId}/{filename} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
