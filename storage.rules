rules_version = '2';

/**
 * CulturePass — Firebase Storage Rules
 *
 * Writes validate image type + size on create/update only (request.resource).
 * Deletes use the same ownership checks without touching request.resource.
 */

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function role() {
      return isSignedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : '';
    }

    function isAdminLike() {
      return role() in ['admin', 'platformAdmin', 'cityAdmin', 'moderator', 'superAdmin'];
    }

    function isOrganizerLike() {
      return role() in ['organizer', 'business', 'sponsor', 'admin', 'platformAdmin', 'cityAdmin', 'superAdmin'];
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function underMB(mb) {
      return request.resource.size < mb * 1024 * 1024
        && request.resource.size > 0;
    }

    function firestoreEventOrganizer(eventId) {
      return firestore.exists(/databases/(default)/documents/events/$(eventId))
        && firestore.get(/databases/(default)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
    }

    function canAccessEventPath(eventId) {
      return isOrganizerLike()
        && (request.auth.uid == eventId || firestoreEventOrganizer(eventId) || isAdminLike());
    }

    function firestoreProfileOwner(profileId) {
      return firestore.exists(/databases/(default)/documents/profiles/$(profileId))
        && firestore.get(/databases/(default)/documents/profiles/$(profileId)).data.ownerId == request.auth.uid;
    }

    function canAccessProfilePath(profileId) {
      return isOrganizerLike()
        && (firestoreProfileOwner(profileId) || isAdminLike());
    }

    // ── Events ─────────────────────────────────────────────────────────────
    match /events/{eventId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if canAccessEventPath(eventId)
        && underMB(10)
        && isValidImage();
      allow delete: if canAccessEventPath(eventId);
    }

    // ── Profiles ───────────────────────────────────────────────────────────
    match /profiles/{profileId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if canAccessProfilePath(profileId)
        && underMB(10)
        && isValidImage();
      allow delete: if canAccessProfilePath(profileId);
    }

    // ── Communities (Firestore: profiles/{id}) ────────────────────────────
    match /communities/{communityId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if canAccessProfilePath(communityId)
        && underMB(10)
        && isValidImage();
      allow delete: if canAccessProfilePath(communityId);
    }

    // ── User avatars ───────────────────────────────────────────────────────
    match /users/{userId}/{filename} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && underMB(5)
        && isValidImage();
      allow delete: if isOwner(userId);
    }

    match /avatars/{userId}/{filename} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && underMB(5)
        && isValidImage();
      allow delete: if isOwner(userId);
    }

    // ── Feed post images ───────────────────────────────────────────────────
    match /posts/{userId}/{filename} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && underMB(10)
        && isValidImage();
      allow delete: if isOwner(userId);
    }

    // ── Admin-managed ──────────────────────────────────────────────────────
    match /perks/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdminLike()
        && underMB(10)
        && isValidImage();
      allow delete: if isAdminLike();
    }

    match /featuredCities/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdminLike()
        && underMB(10)
        && isValidImage();
      allow delete: if isAdminLike();
    }

    // ── Cloud Functions staging — Admin SDK only ───────────────────────────
    match /uploads/{userId}/{filename} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
