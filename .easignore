# EAS Build Upload Ignore — Bare Workflow
# ios/ and android/ source folders are intentionally included.
# Only their generated/cached subdirectories are excluded.

# ── iOS ──────────────────────────────────────────────────────────────────────
# EAS runs `pod install` on its own — no need to upload 1 GB of Pods
ios/Pods
ios/build
ios/DerivedData

# ── Android ──────────────────────────────────────────────────────────────────
# EAS runs Gradle itself — these are local build caches
android/.gradle
android/build
android/app/build

# ── Cloud Functions ───────────────────────────────────────────────────────────
# Not used by the native build; EAS doesn't need this
functions/node_modules
functions/lib

# ── Supplementary server (Docker image service) ──────────────────────────────
server
server/node_modules

# ── Web build outputs ─────────────────────────────────────────────────────────
dist
web-build
static-build
public

# ── Dev / CI tooling ──────────────────────────────────────────────────────────
.git
.github
coverage
codecov
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
jest.config.js
eslint.config.js

# ── DataConnect (exploratory, not deployed) ───────────────────────────────────
dataconnect

# ── Scripts, docs, local dev files ───────────────────────────────────────────
# Note: scripts/ must be included — postinstall runs scripts/fix-metro-core.js
docs
*.md
!README.md
.env.local
*.local.*
*.log
tmp
lint_results.txt
pr_description.md
profile_full.txt
get_sections.py
read_file_full.py
split_components.py
test_review.js
tmp.auth-ui.spec.ts
store.config.json
firebase.json.bak
firestore.indexes.json

# ── Editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
.vscode
*.swp
