{
  "expo": {
    "name": "CulturePass",
    "slug": "culturepass",
    "version": "1.1.0",
    "description": "CulturePass — Your cultural lifestyle platform. Discover events, join diaspora communities, find local businesses, and celebrate diversity across Australia, New Zealand, UAE, UK & Canada.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "culturepass",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "au.culturepass.app",
      "appleTeamId": "26WGXSNG58",
      "buildNumber": "1",
      "infoPlist": {
        "NSSupportsLiveActivities": true,
        "NSLocationWhenInUseUsageDescription": "CulturePass uses your location to show events and communities near you.",
        "NSCameraUsageDescription": "CulturePass uses the camera to update your profile photo and scan event tickets.",
        "NSPhotoLibraryUsageDescription": "CulturePass accesses your photo library to update your profile photo.",
        "NSPhotoLibraryAddUsageDescription": "CulturePass saves images to your photo library.",
        "NSContactsUsageDescription": "CulturePass accesses your contacts to help you connect with friends on the platform.",
        "NSFaceIDUsageDescription": "CulturePass uses Face ID for quick and secure sign-in.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false,
        "googleMapsApiKey": "$(EXPO_PUBLIC_GOOGLE_MAPS_KEY)"
      },
      "associatedDomains": [
        "applinks:culturepass.app",
        "webcredentials:culturepass.app"
      ],
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "au.culturepass.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0B0B14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "culturepass.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "name": "CulturePass — Cultural Events & Communities",
      "shortName": "CulturePass",
      "description": "Discover cultural events, join diaspora communities, find local businesses, and celebrate diversity. CulturePass connects you with cultural experiences across Australia, New Zealand, UAE, UK & Canada.",
      "lang": "en-AU",
      "themeColor": "#2C2A72",
      "backgroundColor": "#0B0B14",
      "display": "standalone",
      "orientation": "portrait",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.$(EXPO_PUBLIC_GOOGLE_REVERSED_CLIENT_ID)"
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CulturePass uses your location to show events and communities near you."
        }
      ],
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "CulturePass uses the camera to scan event QR codes and update your profile photo."
        }
      ],
      "expo-localization",
      "@bacons/apple-targets",
      [
        "react-native-maps",
        {
          "googleMaps": true
        }
      ],
      "@sentry/react-native",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 26,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4bb2f141-de49-47d5-9212-e23e8c0b61d4",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "au.culturepass.app.widget",
                  "targetName": "widget",
                  "entitlements": {}
                },
                {
                  "bundleIdentifier": "au.culturepass.app.spotlight",
                  "targetName": "spotlight",
                  "entitlements": {}
                },
                {
                  "bundleIdentifier": "au.culturepass.app.smart-card",
                  "targetName": "smartcard",
                  "entitlements": {}
                }
              ]
            }
          }
        }
      }
    },
    "owner": "cultureos-org",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/75b9744f-257a-43c6-8245-6bb75fe2b7e8"
    }
  }
}
