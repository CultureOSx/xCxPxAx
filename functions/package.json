{
  "name": "functions",
  "scripts": {
    "build": "tsc && mkdir -p lib/functions/src/data && cp src/data/AllCouncilsList.csv lib/functions/src/data/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed:councils:dry": "node scripts/uploadCouncils.js --dry-run",
    "seed:councils:dry:dev": "node scripts/uploadCouncils.js --dry-run --allow-limited-states",
    "seed:councils": "node scripts/uploadCouncils.js",
    "seed:indigenous:dry": "node scripts/seedIndigenousCulture.js --dry-run",
    "seed:indigenous": "node scripts/seedIndigenousCulture.js"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/functions/src/index.js",
  "dependencies": {
    "@tootallnate/once": "3.0.1",
    "@types/helmet": "^0.0.48",
    "algoliasearch": "^5.49.2",
    "cheerio": "^1.2.0",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.0.6",
    "geofire-common": "^6.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "passkit-generator": "^3.5.7",
    "sharp": "^0.34.5",
    "stripe": "^20.0.0",
    "thumbhash": "^0.1.1",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.0.0",
    "firebase-functions-test": "^3.4.1",
    "jest": "~29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.3"
  },
  "private": true,
  "overrides": {
    "@tootallnate/once@<=3.0.1": "3.0.1"
  }
}
